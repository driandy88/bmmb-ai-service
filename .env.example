# Copy this file to .env and fill in your own values. .env is git-ignored.

# Not required by the API itself (the Gemini key is passed per-request as a
# form field) -- this is only used by the test notebook so you don't have to
# paste your key into every cell.
GEMINI_API_KEY=

# Comma-separated list of allowed frontend origins, or "*" for local dev only.
ALLOWED_ORIGINS=*
