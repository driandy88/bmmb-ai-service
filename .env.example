# Copy this file to .env and fill in your own values. .env is git-ignored.

# Required. The GCP project whose Vertex AI API this service calls.
GCP_PROJECT_ID=prototype-bmmb-1b62

# Optional -- defaults to asia-southeast1 (matches Cloud Run region).
VERTEX_LOCATION=asia-southeast1

# Auth is via Application Default Credentials, not a key in this file.
# One-time local setup (needs the gcloud CLI):
#   gcloud auth application-default login
# On Cloud Run, ADC resolves automatically to the attached service account
# (extraction-service-sa) -- nothing to configure there beyond IAM roles.

# Comma-separated list of allowed frontend origins, or "*" for local dev only.
ALLOWED_ORIGINS=*

# Which BigQuery dataset templates/attributes are read from: "dev" or "prod"
# -> docs_extractor_{APP_ENV}. Same convention as the Express backend
# (bmmb-sme-financing-platform/backend/src/db/bigquery.js) so both point at
# the same tables for a given environment. Reuses GCP_PROJECT_ID above and
# the same ADC credentials -- no separate auth needed.
APP_ENV=dev
