# Copy this file to .env and fill in your own values. .env is git-ignored.

# Required. The GCP project whose Vertex AI API this service calls.
GCP_PROJECT_ID=prototype-bmmb-1b62

# Optional -- defaults to asia-southeast1 (matches Cloud Run region).
VERTEX_LOCATION=asia-southeast1

# Auth is via Application Default Credentials, not a key in this file.
# One-time local setup (needs the gcloud CLI):
#   gcloud auth application-default login
# On Cloud Run, ADC resolves automatically to the attached service account
# (extraction-service-sa) -- nothing to configure there beyond IAM roles.

# Comma-separated list of allowed frontend origins, or "*" for local dev only.
ALLOWED_ORIGINS=*

# Which Cloud SQL database templates/attributes are read from: "dev" or
# "prod" -> bmmb_{APP_ENV}. Same convention as the Express backend so both
# point at the same tables for a given environment.
APP_ENV=dev

# --- Cloud SQL (PostgreSQL) -------------------------------------------
# Required. "project:region:instance", e.g.
#   prototype-bmmb-1b62:asia-southeast1:docs-extractor
# Find it with: gcloud sql instances describe INSTANCE_NAME --format="value(connectionName)"
INSTANCE_CONNECTION_NAME=

# Required. A Postgres user/role created on the instance (see README
# "Cloud SQL setup"). Never commit real credentials -- this file only holds
# placeholders; your actual values live in .env, which is git-ignored.
DB_USER=
DB_PASS=

# Optional -- defaults to bmmb_{APP_ENV} (see APP_ENV above).
# DB_NAME=

# Optional -- set to "true" only if the extraction service has a Serverless
# VPC Access connector attached and the Cloud SQL instance is reachable on
# its private IP. Defaults to "false" (public IP; still TLS-encrypted and
# IAM-authorized via the Cloud SQL connector, no proxy needed).
# DB_USE_PRIVATE_IP=false

# Connection itself goes through the Cloud SQL Python Connector, which
# authorizes using the same Application Default Credentials as
# GCP_PROJECT_ID above (the connecting principal needs the
# "Cloud SQL Client" IAM role) -- nothing extra to configure there.
